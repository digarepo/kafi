{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "jsx": "react-jsx",
    "noEmit": false,
    "paths": {
      "@kafi/ui": ["./src/index.ts"],
      "@kafi/ui/*": ["./src/*"],
      "@ui/*": ["./src/*"],
      "@kafi/ui/base.css": ["./src/styles/base.css"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
