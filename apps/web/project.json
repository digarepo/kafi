{
  "name": "@kafi/web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/web",
  "projectType": "application",
  "tags": [
    "type:app",
    "scope:web"
  ],
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/web",
        "command": "react-router dev --port 3001"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/build"
      ],
      "options": {
        "cwd": "apps/web",
        "command": "react-router build"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/web",
        "command": "react-router typegen && tsc --noEmit"
      }
    }
  }
}
